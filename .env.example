# BookerBlitz Admin Dashboard — Environment Variables
# Copy this file to .env and fill in your values.

# ─── Supabase ───────────────────────────────────────────────────────────────
# Your Supabase project URL (found in Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (found in Project Settings → API)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Twitter / X API ────────────────────────────────────────────────────────
# Create a developer app at https://developer.twitter.com/
# Bearer Token (for read-only lookups)
VITE_TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# API Key and Secret (OAuth 1.0a — for posting)
VITE_TWITTER_API_KEY=your-twitter-api-key
VITE_TWITTER_API_SECRET=your-twitter-api-secret

# Access Token and Secret (OAuth 1.0a — for posting as a specific account)
VITE_TWITTER_ACCESS_TOKEN=your-twitter-access-token
VITE_TWITTER_ACCESS_TOKEN_SECRET=your-twitter-access-token-secret

# ─── Reddit API ─────────────────────────────────────────────────────────────
# Create an app at https://www.reddit.com/prefs/apps (script type)
VITE_REDDIT_CLIENT_ID=your-reddit-client-id
VITE_REDDIT_CLIENT_SECRET=your-reddit-client-secret

# Reddit account credentials for posting
VITE_REDDIT_USERNAME=your-reddit-username
VITE_REDDIT_PASSWORD=your-reddit-password
